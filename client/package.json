{
  "name": "client",
  "private": true,
  "version": "1.0.0",
  "description": "bEdge CRM",
  "author": "Jinit Mewada",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run clean && npm run build && electron-builder",
    "clean": "rimraf dist build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron ."
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.0.0",
    "axios": "^1.11.0",
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1",
    "react": "^19.1.1",
    "react-csv": "^2.2.2",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^38.1.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "rimraf": "^6.0.1",
    "vite": "^7.1.2"
  },
  "build": {
    "appId": "com.bedge.crm",
    "productName": "Bedge CRM",
    "files": [
      "build/**/*",
      "main.js",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "asar": true,
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "asarUnpack": [],
    "npmRebuild": false
  }
}